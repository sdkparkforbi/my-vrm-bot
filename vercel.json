{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/rag", "destination": "/index.html" },
    { "source": "/survey", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" }
  ]
}
