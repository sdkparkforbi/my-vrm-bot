# ════════════════════════════════════════════════════════════
#  봇 배포 시 Vercel 환경변수 (Settings → Environment Variables)
# ════════════════════════════════════════════════════════════

# 내 봇 닉네임 (영문 소문자/숫자/하이픈, 예: bungae)
# ★ 모든 봇 데이터(지식·페르소나·설문)가 이 값으로 구분됩니다.
#   백엔드가 genaiuda.rag_<BOT_ID>, survey_<BOT_ID> 테이블을 자동 생성.
BOT_ID=
VITE_BOT_ID=          # 위 BOT_ID 와 똑같은 값

# 카카오 로그인용 JavaScript 키 (카카오 개발자 콘솔 → 앱 → JavaScript 키)
VITE_KAKAO_JS_KEY=

# (선택) LLM 채팅 엔드포인트. 비워두면 코드 기본값(aiforalab 중계)을 사용 → 그대로 작동.
# ONPREMISE_CHAT_STREAM_URL=

# ── 페이지 안내 ──
#   /         봇 (아바타 + 채팅)
#   /rag      지식·페르소나 관리 (로그인)
#   /survey   설문 만들기 (로그인)
#   /dashboard 설문 결과 공개 대시보드 (비번 없음)
